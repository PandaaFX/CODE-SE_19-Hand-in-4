<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <meta
      name="description"
      content="Manage your NoteNova profile, update your information, and control your account settings."
    />
    <link rel="stylesheet" href="/assets/css/global.css" />
    <link rel="stylesheet" href="/assets/css/panel.css" />
  </head>
  <body class="panel-page">
    <nav>
      <span class="company-name">NoteNova</span>
      <ul>
        <li class="nav-item">
          <a href="/">Home</a>
        </li>
        <li class="nav-item">
          <a href="/features">Features</a>
        </li>
        <li class="nav-item">
          <a href="#">Pricing</a>
        </li>
      </ul>
    </nav>

    <main class="panel-main">
      <div class="panel-header">
        <h1>Account Settings</h1>
        <a href="/logout" class="btn-logout" id="btn-logout">Log out</a>
      </div>

      <div class="panel-card" id="profile-card">
        <div class="profile-card-inner">
          <div class="avatar-section">
            <div class="avatar-wrapper" id="avatar-wrapper">
              <img
                class="avatar-img"
                id="avatar-img"
                src="/assets/images/default-avatar.png"
                alt="avatar"
              />
              <div class="avatar-overlay" title="Change avatar">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71
                    7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41
                    0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                  />
                </svg>
              </div>
            </div>

            <div class="avatar-info">
              <h2>
                <%= user.firstname %> <%= user.lastname %>
              </h2>
              <p class="avatar-email">
                <%= user.email %>
              </p>
              <p class="join-date">
                Member since <%= new Date(user.created_at).toLocaleDateString("en-US", { day: "2-digit", month: "long", year: "numeric" }) %>
              </p>
            </div>
          </div>

          <div class="profile-divider"></div>

          <div class="profile-stats">
            <div class="profile-stat">
              <span class="profile-stat-label">First name</span>
              <span
                class="profile-stat-value"
                ><%= user.firstname %></span
              >
            </div>
            <div class="profile-stat">
              <span class="profile-stat-label">Last name</span>
              <span
                class="profile-stat-value"
                ><%= user.lastname %>
            </div>
            <div class="profile-stat">
              <span class="profile-stat-label">Account ID</span>
              <span class="profile-stat-value"># <%= user.id %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="panel-card" id="info-card">
        <h3 class="panel-card-title">Personal Information</h3>
        <p class="panel-card-sub">Update your name and email address.</p>

        <form
          class="panel-form"
          id="update-info-form"
          action="/panel/updateUserData"
          data-form-action="panel/updateUserData"
          method="POST"
          data-form-method="PATCH"
        >
          <div class="fields-grid">
            <div class="field-group">
              <label class="field-label" for="field-firstname"
                >First name</label
              >
              <input
                class="field-value"
                id="field-firstname"
                type="text"
                name="firstname"
                placeholder="<%= user.firstname %>"
              />
            </div>

            <div class="field-group">
              <label class="field-label" for="field-lastname">Last name</label>
              <input
                class="field-value"
                id="field-lastname"
                type="text"
                name="lastname"
                placeholder="<%= user.lastname %>"
              />
            </div>

            <div class="field-group full-width">
              <label class="field-label" for="field-email">Email address</label>
              <input
                class="field-value"
                id="field-email"
                type="email"
                name="email"
                placeholder="<%= user.email %>"
              />
            </div>
          </div>

          <div class="panel-actions">
            <button class="btn-cancel" type="reset" id="btn-cancel-info">
              Cancel
            </button>
            <button class="btn-save" type="submit" id="btn-save-info">
              Save Changes
            </button>
          </div>
        </form>
      </div>

      <div class="panel-card" id="password-card">
        <h3 class="panel-card-title">Change Password</h3>
        <p class="panel-card-sub">
          Secure your account with a new password.<br />Note: You will be logged
          out after the password change!
        </p>

        <form
          class="panel-form"
          id="update-password-form"
          action="/panel/changePassword"
          data-form-action="panel/changePassword"
          method="POST"
          data-form-method="PATCH"
        >
          <div class="password-fields">
            <div class="field-group">
              <label class="field-label" for="field-current-password"
                >Current password</label
              >
              <input
                class="field-value"
                id="field-current-password"
                type="password"
                name="currentPassword"
                placeholder="Enter current password"
                autocomplete="current-password"
              />
            </div>

            <div class="fields-grid">
              <div class="field-group">
                <label class="field-label" for="field-new-password"
                  >New password</label
                >
                <input
                  class="field-value"
                  id="field-new-password"
                  type="password"
                  name="newPassword"
                  placeholder="New password"
                  autocomplete="new-password"
                />
              </div>

              <div class="field-group">
                <label class="field-label" for="field-confirm-password"
                  >Confirm new password</label
                >
                <input
                  class="field-value"
                  id="field-confirm-password"
                  type="password"
                  name="confirmNewPassword"
                  placeholder="Confirm new password"
                  autocomplete="new-password"
                />
              </div>
            </div>
          </div>

          <div class="panel-actions">
            <button class="btn-cancel" type="reset" id="btn-cancel-password">
              Cancel
            </button>
            <button class="btn-save" type="submit" id="btn-save-password">
              Update Password
            </button>
          </div>
        </form>
      </div>

      <div class="panel-card danger" id="danger-card">
        <h3 class="panel-card-title">Danger Zone</h3>
        <div class="danger-body">
          <p>
            Permanently delete your account and all associated data. This action
            cannot be undone.
          </p>
          <button class="btn-delete" type="button" id="btn-open-delete-modal">
            Delete Account
          </button>
        </div>
      </div>
    </main>

    <div class="modal-backdrop" id="delete-modal">
      <div class="modal-box">
        <h3>Are you sure?</h3>
        <p>
          This will permanently delete your account, notes, and all data. You
          won't be able to recover anything.
        </p>
        <div class="modal-actions">
          <button class="btn-cancel" id="btn-cancel-delete" type="button">
            Keep Account
          </button>
          <form
            action="/panel/deleteAccount"
            data-form-action="panel/deleteAccount"
            method="POST"
            data-form-method="DELETE"
            style="flex: 1"
          >
            <button
              class="btn-delete"
              id="btn-confirm-delete"
              type="submit"
              style="width: 100%"
            >
              Yes, Delete
            </button>
          </form>
        </div>
      </div>
    </div>

    <footer>
      <div class="footer-container">
        <span>&copy; 2026 NoteNova</span>
        <ul class="footer-links">
          <li><a href="#">Privacy</a></li>
          <li><a href="#">Terms</a></li>
        </ul>
      </div>
    </footer>

    <script src="/assets/js/global.js"></script>
    <script src="/assets/js/formHandler.js"></script>
    <script src="/assets/js/panel.js"></script>
  </body>
</html>
